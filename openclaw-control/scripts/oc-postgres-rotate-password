#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODE="${1:-dry-run}"

if [[ -f "$ROOT/../.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT/../.env"
  set +a
fi

if [[ -z "${SERVER_USER:-}" || -z "${SERVER_IP:-${SERVER_HOST:-}}" ]]; then
  echo "SERVER_USER and SERVER_IP or SERVER_HOST are required"
  exit 1
fi

HOST="${SERVER_IP:-$SERVER_HOST}"
export SSHPASS="${SERVER_PASSWORD:-}"
SSH=(ssh -o StrictHostKeyChecking=no "$SERVER_USER@$HOST")
if [[ -n "${SERVER_PASSWORD:-}" ]] && command -v sshpass >/dev/null 2>&1; then
  SSH=(sshpass -e ssh -o StrictHostKeyChecking=no "$SERVER_USER@$HOST")
fi

echo "[oc-postgres-rotate-password] mode=$MODE"
echo "[oc-postgres-rotate-password] remote target: postgres role + /root/.env + dependent services"
[[ "$MODE" == "apply" ]] || exit 0

"${SSH[@]}" "set -euo pipefail
  test -f /root/.env
  mkdir -p /tmp/openclaw-control-backups/env
  cp /root/.env /tmp/openclaw-control-backups/env/root.env.pg-rotate.\$(date +%Y%m%d-%H%M%S)
  new_password=\$(openssl rand -hex 24)
  docker exec ai-office-postgres psql -U postgres -d \${POSTGRES_DB:-ai_office} -v ON_ERROR_STOP=1 -c \"ALTER USER postgres WITH PASSWORD '\${new_password}';\"
  if grep -q '^POSTGRES_PASSWORD=' /root/.env; then
    sed -i \"s|^POSTGRES_PASSWORD=.*|POSTGRES_PASSWORD=\${new_password}|\" /root/.env
  else
    printf '\nPOSTGRES_PASSWORD=%s\n' \"\${new_password}\" >> /root/.env
  fi
  chmod 600 /root/.env
  systemctl restart openclaw.service ai-office-ui.service
  systemctl is-active openclaw.service >/dev/null
  systemctl is-active ai-office-ui.service >/dev/null
  set -a
  source /root/.env
  set +a
  /opt/ai-office/mempalace-venv/bin/python -c \"import os, psycopg2; conn=psycopg2.connect(host='127.0.0.1', port=5432, dbname=os.environ.get('POSTGRES_DB','ai_office'), user=os.environ.get('POSTGRES_USER','postgres'), password=os.environ.get('POSTGRES_PASSWORD','')); cur=conn.cursor(); cur.execute('select 1'); print(cur.fetchone()[0]); conn.close()\" >/tmp/openclaw-postgres-rotate-check.out
  cat /tmp/openclaw-postgres-rotate-check.out
  echo '[oc-postgres-rotate-password] rotation applied and validated'
"
