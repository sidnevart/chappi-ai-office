#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODE="${1:-dry-run}"

if [[ -f "$ROOT/../.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT/../.env"
  set +a
fi

if [[ -z "${SERVER_USER:-}" || -z "${SERVER_IP:-${SERVER_HOST:-}}" ]]; then
  echo "SERVER_USER and SERVER_IP or SERVER_HOST are required"
  exit 1
fi

HOST="${SERVER_IP:-$SERVER_HOST}"
export SSHPASS="${SERVER_PASSWORD:-}"
SSH=(ssh -o StrictHostKeyChecking=no "$SERVER_USER@$HOST")
if [[ -n "${SERVER_PASSWORD:-}" ]] && command -v sshpass >/dev/null 2>&1; then
  SSH=(sshpass -e ssh -o StrictHostKeyChecking=no "$SERVER_USER@$HOST")
fi

echo "[oc-webhook-bootstrap-secret] mode=$MODE"
echo "[oc-webhook-bootstrap-secret] remote target: /root/.env"
[[ "$MODE" == "apply" ]] || exit 0

"${SSH[@]}" "set -euo pipefail
  test -f /root/.env
  set -a
  source /root/.env
  set +a
  if [[ -n \"\${GITHUB_WEBHOOK_SECRET:-}\" ]]; then
    echo '[oc-webhook-bootstrap-secret] remote env already has GITHUB_WEBHOOK_SECRET'
    exit 0
  fi
  mkdir -p /tmp/openclaw-control-backups/env
  cp /root/.env /tmp/openclaw-control-backups/env/root.env.\$(date +%Y%m%d-%H%M%S)
  secret=\$(openssl rand -hex 32)
  printf '\nGITHUB_WEBHOOK_SECRET=%s\n' \"\$secret\" >> /root/.env
  chmod 600 /root/.env
  echo '[oc-webhook-bootstrap-secret] remote env updated'
"
