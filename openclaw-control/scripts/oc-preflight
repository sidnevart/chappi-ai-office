#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODE="${1:-local}"
FAIL=0

if [[ -f "$ROOT/../.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT/../.env"
  set +a
fi

check_bin() {
  local name="$1"
  if command -v "$name" >/dev/null 2>&1; then
    echo "[oc-preflight] found binary: $name"
  else
    echo "[oc-preflight] missing binary: $name"
    FAIL=1
  fi
}

check_env() {
  local name="$1"
  if [[ -n "${!name:-}" ]]; then
    echo "[oc-preflight] env ok: $name"
  else
    echo "[oc-preflight] env missing: $name"
    FAIL=1
  fi
}

echo "[oc-preflight] mode=$MODE"
check_bin openclaw
check_bin python3
check_bin docker
check_bin rg

case "$MODE" in
  local)
    check_env OPENCLAW_GATEWAY_TOKEN
    check_env OPENCLAW_ALLOWED_ORIGIN
    ;;
  vps)
    check_env SERVER_USER
    if [[ -z "${SERVER_IP:-${SERVER_HOST:-}}" ]]; then
      echo "[oc-preflight] env missing: SERVER_IP or SERVER_HOST"
      FAIL=1
    else
      echo "[oc-preflight] env ok: SERVER_IP/SERVER_HOST"
    fi
    if [[ -n "${GITHUB_WEBHOOK_SECRET:-}" ]]; then
      echo "[oc-preflight] env ok: GITHUB_WEBHOOK_SECRET"
    else
      echo "[oc-preflight] env missing: GITHUB_WEBHOOK_SECRET"
    fi
    HOST="${SERVER_IP:-$SERVER_HOST}"
    SSH=(ssh -o StrictHostKeyChecking=no "$SERVER_USER@$HOST")
    if [[ -n "${SERVER_PASSWORD:-}" ]] && command -v sshpass >/dev/null 2>&1; then
      export SSHPASS="$SERVER_PASSWORD"
      SSH=(sshpass -e ssh -o StrictHostKeyChecking=no "$SERVER_USER@$HOST")
    fi
    if "${SSH[@]}" "test -f /root/.env"; then
      echo "[oc-preflight] remote env file present: /root/.env"
    else
      echo "[oc-preflight] remote env file missing: /root/.env"
      FAIL=1
    fi
    if "${SSH[@]}" "source /root/.env && [[ -n \"\${GITHUB_WEBHOOK_SECRET:-}\" ]]"; then
      echo "[oc-preflight] remote env ok: GITHUB_WEBHOOK_SECRET"
    else
      echo "[oc-preflight] remote env missing: GITHUB_WEBHOOK_SECRET"
      FAIL=1
    fi
    if "${SSH[@]}" "command -v nginx >/dev/null 2>&1"; then
      echo "[oc-preflight] remote binary ok: nginx"
    else
      echo "[oc-preflight] remote binary missing: nginx"
      FAIL=1
    fi
    ;;
  *)
    echo "usage: oc-preflight [local|vps]"
    exit 1
    ;;
esac

test -f "$ROOT/openclaw.json.template" || { echo "[oc-preflight] missing template"; FAIL=1; }
test -f "$ROOT/hooks/registry.yaml" || { echo "[oc-preflight] missing hook registry"; FAIL=1; }
test -f "$ROOT/policies/approvals.yaml" || { echo "[oc-preflight] missing approvals policy"; FAIL=1; }

# Local config cleanup: strip deprecated OpenClaw keys that break 2026.2.x validation
LOCAL_CONFIG="${HOME}/.openclaw/openclaw.json"
if [[ -f "$LOCAL_CONFIG" ]]; then
  if node -e "
const fs=require('fs');
const p=process.argv[1];
const cfg=JSON.parse(fs.readFileSync(p,'utf8'));
let needsFix=false;
if (cfg.gateway && Object.prototype.hasOwnProperty.call(cfg.gateway,'url')) needsFix=true;
if (cfg.agents?.defaults?.subagents && Object.prototype.hasOwnProperty.call(cfg.agents.defaults.subagents,'enabled')) needsFix=true;
if (Array.isArray(cfg.agents?.list)) {
  for (const a of cfg.agents.list) {
    if (Object.prototype.hasOwnProperty.call(a,'description')) needsFix=true;
    if (Object.prototype.hasOwnProperty.call(a,'heartbeat')) needsFix=true;
  }
}
process.exit(needsFix ? 0 : 1);
" "$LOCAL_CONFIG"; then
    cp "$LOCAL_CONFIG" "$LOCAL_CONFIG.bak-$(date +%Y%m%d-%H%M%S)"
    node -e "
const fs=require('fs');
const p=process.argv[1];
const cfg=JSON.parse(fs.readFileSync(p,'utf8'));
if (cfg.gateway) delete cfg.gateway.url;
if (cfg.agents?.defaults?.subagents) {
  delete cfg.agents.defaults.subagents.enabled;
  if (Object.keys(cfg.agents.defaults.subagents).length===0) delete cfg.agents.defaults.subagents;
}
if (Array.isArray(cfg.agents?.list)) {
  for (const a of cfg.agents.list) {
    delete a.description;
    delete a.heartbeat;
  }
}
fs.writeFileSync(p, JSON.stringify(cfg,null,2)+'\n');
" "$LOCAL_CONFIG"
    echo "[oc-preflight] removed stale OpenClaw config keys from $LOCAL_CONFIG"
  fi
fi

if [[ "$FAIL" -ne 0 ]]; then
  echo "[oc-preflight] failed"
  exit 1
fi

echo "[oc-preflight] ok"
