[Unit]
Description=OpenClaw Control Gateway
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/root/.env
WorkingDirectory=/root
ExecStartPre=/usr/local/sbin/openclaw-config-guard.sh
ExecStartPre=/usr/local/sbin/openclaw-preflight.sh
ExecStart=/usr/bin/openclaw gateway run --port 18789 --bind lan --ws-log compact
Restart=always
RestartSec=5
TimeoutStartSec=90
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
