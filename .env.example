# Chappi AI Office — шаблон переменных окружения
# Скопируй в .env и заполни своими значениями:
#   cp .env.example .env

# Telegram-бот (получить у @BotFather)
OPENCLAW_TG_BOT=YOUR_TELEGRAM_BOT_TOKEN

# VPS
SERVER_IP=YOUR_VPS_IP
SERVER_USER=root

# PostgreSQL (если используешь docker-compose — пароль задаётся здесь же)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_db_password
POSTGRES_DB=ai_office
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Ollama (по умолчанию — локально на VPS)
OLLAMA_HOST=http://localhost:11434

# Cloudflared туннель (Mac → VPS доступ к файлам)
# Запускается: cd tunnel && cloudflared tunnel --url http://localhost:18500 ...
MAC_FILES_URL=YOUR_CLOUDFLARE_TUNNEL_URL
MAC_FILESERVER_TOKEN=YOUR_FILESERVER_TOKEN

# Composio (интеграции: Gmail, Google Calendar, Notion, GitHub)
# Получить: https://composio.dev → API Keys
COMPOSIO_API_KEY=YOUR_COMPOSIO_KEY

# Star Office UI (можно оставить как есть или поменять)
FLASK_SECRET_KEY=change-this-to-random-string
STAR_OFFICE_SECRET=change-this-to-random-string
ASSET_DRAWER_PASS=change-this-to-random-string

# Уведомления Telegram (chat_id пользователя, узнать у @userinfobot)
TG_NOTIFY_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
